# Eco Mi — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository.

# App Variant — set to "development" for dev builds (uses Google test AdMob IDs)
APP_VARIANT=development

# RevenueCat Public API Keys
REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXX

# AdMob Ad Unit IDs (production)
ADMOB_BANNER_IOS=ca-app-pub-XXXX/YYYY
ADMOB_BANNER_ANDROID=ca-app-pub-XXXX/YYYY
ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXX/YYYY
ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXX/YYYY
ADMOB_REWARDED_IOS=ca-app-pub-XXXX/YYYY
ADMOB_REWARDED_ANDROID=ca-app-pub-XXXX/YYYY

# AdMob App IDs (used in app.config.ts at build time)
ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~ZZZZZZZZZZ
ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXX
