{
  "name": "eco-mi",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "./scripts/tsc-lint-format",
    "align-deps": "npx expo install --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:maestro": "maestro test -e MAESTRO_APP_ID=com.frankcalise.ecomi .maestro/flows/",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "build:ios:sim": "eas build --profile development --platform ios --local",
    "build:ios:dev": "eas build --profile development:device --platform ios --local",
    "build:ios:preview": "eas build --profile preview --platform ios --local",
    "build:ios:prod": "eas build --profile production --platform ios --local",
    "build:android:sim": "eas build --profile development --platform android --local",
    "build:android:dev": "eas build --profile development:device --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:android:prod": "eas build --profile production --platform android --local"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/native": "^7.0.14",
    "@sentry/react-native": "~7.11.0",
    "expo": "^55.0.11",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-eas-client": "^55.0.5",
    "expo-eas-observe": "~0.0.32",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.11",
    "expo-system-ui": "~55.0.13",
    "expo-tracking-transparency": "~55.0.11",
    "expo-updates": "~55.0.19",
    "i18next": "25.4.2",
    "intl-pluralrules": "^2.0.1",
    "lottie-react-native": "~7.3.4",
    "posthog-react-native": "^4.39.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "15.7.2",
    "react-native": "0.83.4",
    "react-native-audio-api": "^0.8.2",
    "react-native-ease": "^0.4.0",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.3.1",
    "react-native-mmkv": "^3.2.0",
    "react-native-purchases": "^9.15.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.13",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}